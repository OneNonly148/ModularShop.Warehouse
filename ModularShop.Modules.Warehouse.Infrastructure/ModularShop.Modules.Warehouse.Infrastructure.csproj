<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <RootNamespace>ModularShop.Modules.Warehouse.Infrastructure</RootNamespace>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\ModularShop.Modules.Warehouse.Application\ModularShop.Modules.Warehouse.Application.csproj" />
    <ProjectReference Include="..\ModularShop.Modules.Warehouse.Domain\ModularShop.Modules.Warehouse.Domain.csproj" />
    <ProjectReference Include="..\..\..\Kernel\ModularShop.Kernel.Infrastructure\ModularShop.Kernel.Infrastructure.csproj" />
    <!-- Warehouse reacts to the Sales OrderPlaced event, so it references the Sales public contract. -->
    <ProjectReference Include="..\..\Sales\ModularShop.Modules.Sales.Contracts\ModularShop.Modules.Sales.Contracts.csproj" />
    <!-- WarehouseModule.Register registers this Api assembly's controllers as an MVC application part
         (AddControllers().AddApplicationPart(typeof(ProductsController)...)) — a REAL, used reference; do NOT
         remove it (removing it silently drops the module's routes). See docs/decision-log.md D13. -->
    <ProjectReference Include="..\ModularShop.Modules.Warehouse.Api\ModularShop.Modules.Warehouse.Api.csproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="MediatR" />
  </ItemGroup>

</Project>
